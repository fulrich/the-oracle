# Supabase's project URL. Local default: http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=

# Safe to expose to the browser. Do not use the service-role key here.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public application origin used for OAuth redirects.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Server-only Google OAuth credential consumed by the local Supabase CLI.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

# Optional exact email restored as the local DM after every database reset.
LOCAL_DM_EMAIL=

# Server-only opt-in for the synthetic local password accounts. Never enable in
# a hosted environment.
